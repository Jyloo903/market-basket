<%- include('../partials/header', { title: 'Admin Dashboard' }) %>

<div class="container mt-4">
  <div class="row mb-4">
    <div class="col">
      <h2 class="fw-bold"><i class="bi bi-shield-lock"></i> Admin Dashboard</h2>
      <p class="text-muted mb-0">Panel kontrol administrator</p>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-md-4 mb-3">
      <div class="card bg-primary text-white h-100 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title mb-1">Total Users</h6>
              <h2 class="mb-0"><%= totalUsers %></h2>
            </div>
            <i class="bi bi-people" style="font-size: 40px; opacity: 0.5;"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-3">
      <div class="card bg-success text-white h-100 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title mb-1">Total Analisis</h6>
              <h2 class="mb-0"><%= totalAnalysis %></h2>
            </div>
            <i class="bi bi-graph-up" style="font-size: 40px; opacity: 0.5;"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-3">
      <div class="card bg-info text-white h-100 shadow-sm">
        <div class="card-body d-flex flex-column justify-content-between h-100">
          <h6 class="card-title mb-2">Aksi Cepat</h6>
          <a href="/admin/users" class="btn btn-light btn-sm align-self-start">
            <i class="bi bi-people"></i> Kelola Users
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><i class="bi bi-list-ul"></i> Analisis Terbaru</h5>
          <span class="badge bg-light text-dark"><%= recentAnalyses ? recentAnalyses.length : 0 %> data</span>
        </div>
        <div class="card-body">
          <% if (recentAnalyses && recentAnalyses.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead class="table-light">
                  <tr>
                    <th>User</th>
                    <th>File</th>
                    <th>Support</th>
                    <th>Confidence</th>
                    <th>Rules</th>
                    <th>Tanggal</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentAnalyses.forEach(analysis => { %>
                    <tr>
                      <td>
                        <i class="bi bi-person"></i>
                        <%= analysis.user ? analysis.user.name : 'Unknown' %>
                      </td>
                      <td><small class="text-muted"><%= analysis.fileName %></small></td>
                      <td><span class="badge bg-success-subtle text-success border border-success"><%= (analysis.parameters.support * 100).toFixed(1) %>%</span></td>
                      <td><span class="badge bg-primary-subtle text-primary border border-primary"><%= (analysis.parameters.confidence * 100).toFixed(1) %>%</span></td>
                      <td><span class="badge bg-secondary"><%= analysis.parameters.totalRules || 0 %></span></td>
                      <td><small class="text-muted"><%= new Date(analysis.createdAt).toLocaleDateString('id-ID') %></small></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-center text-muted py-4 mb-0">Belum ada analisis</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <a href="/admin/users" class="btn btn-primary me-2">
      <i class="bi bi-people"></i> Manage Users
    </a>
    <a href="/dashboard" class="btn btn-secondary">
      <i class="bi bi-arrow-left"></i> User Dashboard
    </a>
  </div>
</div>

<%- include('../partials/footer') %>