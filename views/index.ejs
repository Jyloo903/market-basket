<%- include('partials/header', { title: 'Market Basket Analysis' }) %>

<div class="hero">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1>Analisis Pola Pembelian Pelanggan</h1>
        <p class="lead mb-4">Gunakan algoritma FP-Growth untuk menemukan insight tersembunyi dari data transaksi Anda. Optimalkan strategi cross-selling dan tingkatkan revenue bisnis Anda.</p>
        <div class="d-flex gap-2">
          <% if (typeof user === 'undefined' || !user) { %>
            <a href="/auth/register" class="btn btn-light btn-lg">Mulai Gratis</a>
            <a href="/auth/login" class="btn btn-outline-light btn-lg">Login</a>
          <% } else { %>
            <a href="/mining" class="btn btn-light btn-lg">Upload Analisis</a>
            <a href="/dashboard" class="btn btn-outline-light btn-lg">Dashboard</a>
          <% } %>
        </div>
      </div>
      <div class="col-lg-6 text-center">
        <svg width="300" height="300" viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg" style="opacity: 0.9;">
          <circle cx="150" cy="150" r="140" stroke="white" stroke-width="2" fill="none"/>
          <circle cx="100" cy="120" r="40" stroke="white" stroke-width="2" fill="rgba(255,255,255,0.1)"/>
          <circle cx="200" cy="120" r="40" stroke="white" stroke-width="2" fill="rgba(255,255,255,0.1)"/>
          <circle cx="150" cy="200" r="40" stroke="white" stroke-width="2" fill="rgba(255,255,255,0.1)"/>
          <line x1="100" y1="120" x2="200" y2="120" stroke="white" stroke-width="2" opacity="0.6"/>
          <line x1="100" y1="120" x2="150" y2="200" stroke="white" stroke-width="2" opacity="0.6"/>
          <line x1="200" y1="120" x2="150" y2="200" stroke="white" stroke-width="2" opacity="0.6"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<div class="container my-5">
