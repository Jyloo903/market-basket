        </div>
      </div>
    </div>
    <div class="col-md-6 col-lg-4">
      <div class="feature-card">
        <div class="card-body p-4">
          <div class="mb-3">
            <i class="bi bi-shield-check" style="font-size: 32px; color: #2563eb;"></i>
          </div>
          <h5>Keamanan Data</h5>
          <p class="text-secondary mb-0">Sistem login aman dengan enkripsi dan rate limiting</p>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-lg-4">
      <div class="feature-card">
        <div class="card-body p-4">
          <div class="mb-3">
            <i class="bi bi-person-workspace" style="font-size: 32px; color: #2563eb;"></i>
